{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "packageRules": [
    {
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "groupName": "go minor/patch dependencies"
    },
    {
      "matchManagers": ["github-actions"],
      "automerge": true,
      "groupName": "github actions"
    }
  ]
}